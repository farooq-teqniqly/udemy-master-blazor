@if (Product is not null)
{
    <tr>
        <td>@Product.Name</td>
        <td>@Product.Quantity</td>
        <td>@Product.Price.ToString("C")</td>
        <td>
            <a href="/edit-product/@Product.Id" class="btn btn-outline-primary">Edit</a>
        </td>
    </tr>
}

@code {

    [Parameter]
    public Product? Product { get; set; }

}
