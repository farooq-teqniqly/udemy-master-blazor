@inject IDeleteProductUseCase DeleteProductUseCase

@if (Product is not null)
{
    <tr>
        <td>@Product.Name</td>
        <td>@Product.Quantity</td>
        <td>@Product.Price.ToString("C")</td>
        <td>
            <a href="/edit-product/@Product.Id" class="btn btn-outline-primary">Edit</a>
        </td>
        <td>
            <button type="button" class="btn btn-outline-danger" @onclick="async () => await Delete()">Delete</button>
        </td>
    </tr>
}

@code {

    [Parameter]
    public Product? Product { get; set; }

    private async Task Delete()
    {
        if (Product is not null)
        {
            await DeleteProductUseCase.ExecuteAsync(Product.Id);
            Product = null;
        }
    }
}
