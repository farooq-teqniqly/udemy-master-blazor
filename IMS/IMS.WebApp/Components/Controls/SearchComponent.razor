@{
    searchFilter ??= string.Empty;
}

<EditForm Enhance="true" Model="searchFilter" FormName="formSearch" OnSubmit="Search">
    <div class="input-group">
        <InputText id="name"
                   class="form-control"
                   @bind-Value="searchFilter"
                   placeholder="Search"></InputText>
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </div>
</EditForm>
<br />

@code {
    [SupplyParameterFromForm]
    private string? searchFilter { get; set; }

    [Parameter] public EventCallback<string> OnSearch { get; set; }

    protected override void OnInitialized() => searchFilter ??= string.Empty;

    private async Task Search()
    {
        await OnSearch.InvokeAsync(searchFilter);
    }

}
